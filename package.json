{
  "name": "stirilo",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first system control dashboard for developers",
  "license": "MIT",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsc -b && pnpm --filter @stirilo/web dev",
    "build": "tsc -b && pnpm --filter @stirilo/web build",
    "typecheck": "tsc -b && pnpm --filter @stirilo/web typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "tsc -b && pnpm --filter @stirilo/web test:e2e",
    "docs:api": "tsc -b packages/core && node scripts/generate-api-docs.mjs",
    "setup": "node scripts/setup.mjs",
    "hash:password": "pnpm --filter @stirilo/auth hash:password",
    "db:generate": "pnpm --filter @stirilo/db db:generate",
    "db:migrate": "pnpm --filter @stirilo/db db:migrate",
    "db:studio": "pnpm --filter @stirilo/db db:studio",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@stirilo/core": "workspace:*",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@node-rs/argon2": "^2.0.2",
    "@stylistic/eslint-plugin": "^2.12.1",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "lefthook": "^1.10.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
