# Stirilo environment configuration.
# Copy this file to .env and fill in the values. Never commit .env.

# Public URL the app is served from.
STIRILO_APP_URL=http://localhost:3157

# Local-first: bind to loopback by default. LAN access is opt-in only.
STIRILO_BIND_HOST=127.0.0.1
STIRILO_PORT=3157

# Single-user local auth.
STIRILO_USERNAME=admin
# Hash of the login password (see README for the generation command).
STIRILO_PASSWORD_SHA256=

# Secret used to sign sessions. Generate a long random value.
STIRILO_SESSION_SECRET=

# SQLite database path (dev default). Never commit the database file.
STIRILO_DB_PATH=./data/stirilo.dev.db

# Token for the authenticated HTTP API (separate from the user session).
STIRILO_AGENT_TOKEN=
