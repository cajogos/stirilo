# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
.next-verify/
out/
*.tsbuildinfo
next-env.d.ts.timestamp

# Playwright
test-results/
playwright-report/
playwright/.cache/
blob-report/

# Coverage / test artefacts
coverage/

# Reference PDFs (e.g. the PRD) are never committed
*.pdf

# Environment files (keep the example)
.env*
!.env.example

# Databases (never commit local data)
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Keys and certificates
*.pem
*.key

# Local data directory (keep the folder, ignore contents)
data/*
!data/.gitkeep

# Logs and OS cruft
*.log
.DS_Store
